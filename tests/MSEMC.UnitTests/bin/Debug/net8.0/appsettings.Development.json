{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.AspNetCore": "Information",
        "MassTransit": "Debug"
      }
    }
  },
  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "Username": "your-email@gmail.com",
    "Password": "your-app-password",
    "EnableSsl": true,
    "SenderEmail": "your-email@gmail.com",
    "SenderDisplayName": "MSEMC Dev"
  },
  "ApiKey": {
    "HeaderName": "X-API-Key",
    "Key": "dev-api-key-change-in-production"
  },
  "RabbitMq": {
    "Host": "localhost",
    "Port": 5672,
    "Username": "guest",
    "Password": "guest"
  }
}
